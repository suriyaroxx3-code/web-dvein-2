# ─────────────────────────────────────────────────────────────────────────────
# DVein Backend — Environment Variables
# Copy this file to ".env" and fill in your credentials.
# NEVER commit the real .env file to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── RECOMMENDED: Brevo (Sendinblue) — FREE 9,000 emails/month ────────────────
# 1. Sign up at https://brevo.com  (free, no credit card)
# 2. Go to Settings → SMTP & API → SMTP tab
# 3. Copy login/password from the SMTP table below

SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
EMAIL_USER=your_brevo_login_email@example.com
EMAIL_PASS=your_brevo_smtp_password_here

# The company inbox that receives all form submissions
COMPANY_EMAIL=info@dveininnovations.com


# ── ALTERNATIVE: Gmail App Password ──────────────────────────────────────────
# Use this if you prefer Gmail. Limit: 500 emails/day on free Gmail.
# 1. Enable 2-Factor Authentication on your Google Account
# 2. Go to Google Account → Security → App Passwords
# 3. Generate an App Password for "Mail"
# 4. Use the 16-character app password below (NOT your Gmail login password)
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465          <- change to 465 and update _get_smtp_connection to use SMTP_SSL
# EMAIL_USER=your_gmail@gmail.com
# EMAIL_PASS=xxxx xxxx xxxx xxxx   <- 16-char app password


# ── ALTERNATIVE: SendGrid — FREE 3,000 emails/month ──────────────────────────
# 1. Sign up at https://sendgrid.com
# 2. Settings → API Keys → Create API Key (Full Access)
# 3. Use apikey as EMAIL_USER and the API key as EMAIL_PASS
#
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# EMAIL_USER=apikey
# EMAIL_PASS=SG.your_sendgrid_api_key_here
